    "Unaffiliated third-party client for the self-hosted Bambuddy server. BamPocket talks to it only over its public network API and bundles none of its source code.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unabhängiger, nicht zugehöriger Drittanbieter-Client für den selbst gehosteten Bambuddy-Server. BamPocket kommuniziert mit ihm nur über dessen öffentliche Netzwerk-API und enthält keinen seiner Quellcodes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliente de terceros independiente y no afiliado para el servidor autoalojado Bambuddy. BamPocket se comunica con él solo a través de su API de red pública y no incluye su código fuente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Client tiers indépendant et non affilié pour le serveur auto-hébergé Bambuddy. BamPocket dialogue avec lui uniquement via son API réseau publique et n’embarque aucun de son code source."
          }
        }
      }
    },
    "Unaffiliated third-party client. Trademarks belong to their respective owners.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht verbundener Drittanbieter-Client. Marken gehören ihren jeweiligen Eigentümern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliente de terceros no afiliado. Las marcas pertenecen a sus respectivos dueños."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Client tiers non affilié. Les marques appartiennent à leurs détenteurs respectifs."
          }
        }
      }
    },
    "Unauthorized — check your credentials.": {
