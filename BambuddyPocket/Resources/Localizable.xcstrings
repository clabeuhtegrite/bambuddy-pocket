    "A token with repository write access. Sent to the server, never stored on this device.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A token with repository write access. Sent to the server, never stored on this device."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un jeton avec droit d’écriture sur le dépôt. Envoyé au serveur, jamais stocké sur cet appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un token con permiso de escritura en el repositorio. Se envía al servidor, nunca se almacena en este dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Token mit Schreibzugriff auf das Repository. An den Server gesendet, nie auf diesem Gerät gespeichert."
