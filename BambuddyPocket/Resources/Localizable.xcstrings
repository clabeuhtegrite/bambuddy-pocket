    "Admin features include managing API keys and backups.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zu den Administratorfunktionen gehören die Verwaltung von API-Schlüsseln und Backups."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las funciones de administrador incluyen la gestión de claves de API y copias de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fonctions d’administration incluent la gestion des clés d’API et les sauvegardes."
          }
        }
      }
    },
    "Admin features — managing API keys and backups — require a username & password login.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Administratorfunktionen – Verwaltung von API-Schlüsseln und Backups – erfordern eine Anmeldung mit Benutzername und Passwort."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las funciones de administrador (gestión de claves de API y copias de seguridad) requieren iniciar sesión con usuario y contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
