      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dieser Server verwendet unverschlüsseltes HTTP. Der Datenverkehr ist nicht verschlüsselt; nur in einem vertrauenswürdigen Netzwerk verwenden." } },
